{
  "name": "kayzaapp",
  "version": "1.1.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-build-info.mjs",
    "start": "npx ng serve --host 0.0.0.0 --port 4200",
    "prebuild": "node scripts/generate-build-info.mjs",
    "build": "npx ng build --configuration production --base-href /",
    "watch": "npx ng build --watch --configuration development",
    "test": "npx ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.11.1 <25.0.0",
    "npm": ">=11.12.1 <12.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "bootstrap": "^5.3.8",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
